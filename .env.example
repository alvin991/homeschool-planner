# Copy this file to ".env" and fill in every value. Commit .env.example — never commit .env.
#
# Next.js loads ".env" automatically for `npm run dev` and `npm run build` (not this file).
# Docker Compose uses your real ".env" for the "db" service and the dev container.

NODE_ENV=development

MONGODB_URI=

MONGO_INITDB_DATABASE=homeschool_planner
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
