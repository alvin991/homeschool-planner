# Copy this file to ".env" and fill in every value. Commit .env.example — never commit .env.
#
# Next.js loads ".env" automatically for `npm run dev` and `npm run build` (not this file).
#
# Local Docker dev (docker-compose.yaml): the bundled Mongo service is named "db", so use host "db" below.
# Production (docker-compose.prod.yaml): use your real Mongo hostname on homeschool-net, e.g. "homeschool-mongo".

NODE_ENV=development

MONGODB_URI=

# Only needed for local `docker-compose.yaml` when Compose starts Mongo (first init). Not used by prod compose (external Mongo).
MONGO_INITDB_DATABASE=homeschool_planner
MONGO_INITDB_ROOT_USERNAME=
MONGO_INITDB_ROOT_PASSWORD=
